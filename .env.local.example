# ============================================================
# .env.local — Thapar Campus Commerce
# Copy this file, fill in real values, NEVER commit to git
# ============================================================

# ---- Database (Neon PostgreSQL) ----------------------------
# Get from: https://neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ---- NextAuth ----------------------------------------------
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-32-character-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth (for @thapar.edu Google Workspace login) -
# Get from: https://console.cloud.google.com → APIs → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ---- Razorpay ----------------------------------------------
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys during development (prefix: rzp_test_)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# This one is exposed to the browser (used to init Razorpay modal)
NEXT_PUBLIC_RAZORPAY_KEY="rzp_test_xxxxxxxxxxxxxx"

# ---- App URL (update for production) -----------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
